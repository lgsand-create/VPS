# MariaDB (unix_socket)
DB_USER=root
DB_NAME=minridskola
DB_SOCKET=/var/run/mysqld/mysqld.sock

# API-server
API_PORT=3000

# CRON: Snabb scraping (aktuell vecka) — var 15:e minut
CRON_QUICK=*/15 * * * *

# CRON: Fullscan (hela året) — 1:a varje månad kl 03:00
CRON_FULL=0 3 1 * *

# Sökväg till scraper (relativ från services/)
SCRAPER_PATH=../scrapers/minridskola/scrape.js

# Sökväg till data-mappen (relativ från services/)
DATA_PATH=../data/minridskola

# Externa CRON-triggers (HTTP GET varje minut)
SARF_CRON_URL=https://new.stalladamsrf.se/scheduler/run?token=YOUR_TOKEN
